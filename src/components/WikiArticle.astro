---
import Layout from '../layouts/Layout.astro';
import { wikiPages, type WikiPage } from '../data/wiki';

interface Props {
	page: WikiPage;
}

const { page } = Astro.props;
const relatedPages = page.related.map((slug) => wikiPages[slug]).filter(Boolean);
---

<Layout title={page.title} description={page.summary}>
	<main class="page-shell">
		<section class="page-hero section" style={`--accent: ${page.accent}`}>
			<div>
				<p class="eyebrow">{page.eyebrow}</p>
				<h1>{page.title}</h1>
				<p class="page-hero__summary">{page.summary}</p>
			</div>
			<aside class="quick-card panel" aria-labelledby="quick-tips-heading">
				<span class="kicker">{page.badge}</span>
				<h2 id="quick-tips-heading">Quick tips</h2>
				<ul>
					{page.quickTips.map((tip) => <li>{tip}</li>)}
				</ul>
			</aside>
		</section>

		<section class="section content-grid" aria-label={`${page.title} guide sections`}>
			{
				page.sections.map((section) => (
					<article class="guide-section panel">
						<div class="guide-section__intro">
							<p class="eyebrow">{page.title}</p>
							<h2>{section.heading}</h2>
							{section.body && <p>{section.body}</p>}
						</div>
						<div class="guide-items">
							{section.items.map((item) => (
								<div class="guide-item">
									{item.tag && <span>{item.tag}</span>}
									<h3>{item.title}</h3>
									{
										item.meta && (
											<ul class="guide-meta">
												{item.meta.map((meta) => (
													<li>{meta}</li>
												))}
											</ul>
										)
									}
									<p>{item.text}</p>
									{
										item.steps && (
											<ol class="guide-list guide-list--steps">
												{item.steps.map((step) => (
													<li>{step}</li>
												))}
											</ol>
										)
									}
									{
										item.tips && (
											<ul class="guide-list guide-list--tips">
												{item.tips.map((tip) => (
													<li>{tip}</li>
												))}
											</ul>
										)
									}
									{item.note && <p class="guide-note">{item.note}</p>}
								</div>
							))}
						</div>
					</article>
				))
			}
		</section>

		{
			page.faqs && (
				<section class="faq section panel" aria-labelledby="faq-heading">
					<div>
						<p class="eyebrow">FAQ</p>
						<h2 id="faq-heading">Common questions.</h2>
					</div>
					<div class="faq__items">
						{page.faqs.map((faq) => (
							<details>
								<summary>{faq.question}</summary>
								<p>{faq.answer}</p>
							</details>
						))}
					</div>
				</section>
			)
		}

		<section class="related section" aria-labelledby="related-heading">
			<div>
				<p class="eyebrow">Next trail</p>
				<h2 id="related-heading">Keep building the route.</h2>
			</div>
			<div class="related__cards">
				{
					relatedPages.map((related) => (
						<a href={`/${related.slug}`} style={`--accent: ${related.accent}`}>
							<span>{related.badge}</span>
							<strong>{related.title}</strong>
							<small>{related.summary}</small>
						</a>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<style>
	.page-shell {
		padding-top: 3.2rem;
	}

	.page-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.98fr) minmax(300px, 0.42fr);
		gap: clamp(1.8rem, 6vw, 4.2rem);
		align-items: start;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	.page-hero h1 {
		max-width: 11ch;
		margin-bottom: 1.35rem;
		font-family: var(--font-display);
		font-size: clamp(3.4rem, 9vw, 7.2rem);
		line-height: 0.9;
		letter-spacing: -0.075em;
	}

	.page-hero h1::after {
		display: block;
		width: clamp(6rem, 22vw, 14rem);
		height: 0.4rem;
		margin-top: 1.15rem;
		content: '';
		border-radius: 999px;
		background: var(--accent);
	}

	.page-hero__summary {
		max-width: 42rem;
		margin-bottom: 0;
		color: var(--ink-muted);
		font-size: clamp(1.06rem, 1.85vw, 1.22rem);
		line-height: 1.78;
	}

	.quick-card {
		position: relative;
		overflow: hidden;
		padding: 1.45rem;
	}

	.quick-card::after {
		position: absolute;
		right: -4rem;
		bottom: -5rem;
		z-index: -1;
		width: 13rem;
		height: 13rem;
		content: '';
		border-radius: 45% 55% 50% 50%;
		background: color-mix(in srgb, var(--accent) 20%, transparent);
	}

	.quick-card h2 {
		margin: 1.2rem 0 0.8rem;
		font-family: var(--font-display);
		font-size: 2rem;
		line-height: 1;
		letter-spacing: -0.05em;
	}

	.quick-card ul {
		display: grid;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.quick-card li {
		position: relative;
		padding-left: 1.25rem;
		color: var(--ink-muted);
		line-height: 1.55;
	}

	.quick-card li::before {
		position: absolute;
		top: 0.62em;
		left: 0;
		width: 0.45rem;
		height: 0.45rem;
		content: '';
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 0 0.25rem color-mix(in srgb, var(--accent) 16%, transparent);
	}

	.content-grid {
		display: grid;
		gap: 1.45rem;
		margin-top: clamp(4.5rem, 8vw, 6.5rem);
	}

	.guide-section {
		display: grid;
		grid-template-columns: 0.38fr 0.62fr;
		gap: clamp(1.6rem, 5vw, 3.2rem);
		padding: clamp(1.35rem, 4vw, 2.2rem);
	}

	.guide-section__intro {
		position: sticky;
		top: 6rem;
		align-self: start;
	}

	.guide-section__intro h2,
	.related h2 {
		max-width: 13ch;
		margin-bottom: 0.95rem;
		font-family: var(--font-display);
		font-size: clamp(2.1rem, 5vw, 3.6rem);
		line-height: 0.95;
		letter-spacing: -0.07em;
	}

	.guide-section__intro p:not(.eyebrow),
	.guide-item p,
	.related small {
		color: var(--ink-muted);
		line-height: 1.65;
	}

	.guide-items {
		display: grid;
		gap: 1rem;
	}

	.guide-item {
		position: relative;
		overflow: hidden;
		padding: 1.15rem 1.25rem;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 22px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.48)),
			radial-gradient(circle at right top, color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%);
	}

	.guide-item span {
		display: inline-flex;
		margin-bottom: 0.7rem;
		padding: 0.32rem 0.52rem;
		color: var(--deep);
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 20%, white);
	}

	.guide-item h3 {
		margin-bottom: 0.55rem;
		font-family: var(--font-display);
		font-size: 1.62rem;
		line-height: 1;
		letter-spacing: -0.05em;
	}

	.guide-item p {
		margin-bottom: 0;
	}

	.guide-meta {
		display: flex;
		gap: 0.45rem;
		flex-wrap: wrap;
		margin: 0 0 0.8rem;
		padding: 0;
		list-style: none;
	}

	.guide-meta li {
		padding: 0.28rem 0.52rem;
		color: var(--ink-muted);
		font-size: 0.78rem;
		font-weight: 850;
		border: 1px solid color-mix(in srgb, var(--accent) 22%, white);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.62);
	}

	.guide-list {
		display: grid;
		gap: 0.45rem;
		margin: 0.85rem 0 0;
		padding-left: 1.2rem;
		color: var(--ink-muted);
		line-height: 1.55;
	}

	.guide-list li::marker {
		color: var(--accent);
		font-weight: 900;
	}

	.guide-list--tips {
		padding-left: 1rem;
		list-style: square;
	}

	.guide-note {
		margin-top: 0.85rem;
		padding: 0.75rem 0.85rem;
		color: var(--deep);
		font-size: 0.92rem;
		border-radius: 16px;
		background: color-mix(in srgb, var(--accent) 12%, white);
	}

	.faq {
		display: grid;
		grid-template-columns: 0.34fr 0.66fr;
		gap: clamp(1.6rem, 5vw, 3.2rem);
		margin-top: clamp(4.5rem, 8vw, 6.5rem);
		padding: clamp(1.35rem, 4vw, 2.2rem);
	}

	.faq h2 {
		max-width: 13ch;
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2.1rem, 5vw, 3.6rem);
		line-height: 0.95;
		letter-spacing: -0.07em;
	}

	.faq__items {
		display: grid;
		gap: 0.75rem;
	}

	.faq details {
		padding: 1rem 1.15rem;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.58);
	}

	.faq summary {
		cursor: pointer;
		color: var(--ink);
		font-weight: 950;
	}

	.faq details p {
		margin: 0.75rem 0 0;
		color: var(--ink-muted);
		line-height: 1.65;
	}

	.related {
		display: grid;
		grid-template-columns: 0.34fr 0.66fr;
		gap: clamp(1.6rem, 5vw, 3.2rem);
		align-items: start;
		margin-top: clamp(4.5rem, 8vw, 6.5rem);
	}

	.related__cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.1rem;
	}

	.related__cards a {
		position: relative;
		min-height: 12.2rem;
		overflow: hidden;
		padding: 1.15rem;
		text-decoration: none;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 22px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.5)),
			radial-gradient(circle at top right, color-mix(in srgb, var(--accent) 18%, transparent), transparent 56%);
		box-shadow: 0 14px 42px rgba(10, 38, 54, 0.09);
		transition: transform 180ms ease;
	}

	.related__cards a:hover {
		transform: translateY(-4px);
	}

	.related__cards span {
		display: block;
		margin-bottom: 0.9rem;
		color: var(--pine);
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.related__cards strong {
		display: block;
		margin-bottom: 0.55rem;
		font-family: var(--font-display);
		font-size: 1.5rem;
		line-height: 1;
		letter-spacing: -0.05em;
	}

	.related__cards small {
		display: block;
		font-size: 0.9rem;
	}

	@media (max-width: 980px) {
		.page-shell {
			padding-top: 2.4rem;
		}

		.page-hero,
		.guide-section,
		.faq,
		.related {
			grid-template-columns: 1fr;
		}

		.guide-section__intro {
			position: static;
		}
	}

	@media (max-width: 680px) {
		.page-hero h1 {
			font-size: clamp(3.25rem, 17vw, 5.3rem);
		}

		.related__cards {
			grid-template-columns: 1fr;
		}
	}
</style>
